<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Our Services</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

{{>header}}
<body class="bg-light">

<!-- HERO -->
<div class="bg-dark text-light py-5">
  <div class="container text-center">

    <h1 class="fw-bold text-warning">Our Services 🚀</h1>
    <p class="lead">We provide best shopping experience for our customers</p>

  </div>
</div>

<!-- SERVICES -->
<div class="container my-5">

  <div class="row g-4 text-center">

    <!-- Service 1 -->
    <div class="col-md-4">
      <div class="p-4 shadow-sm bg-white rounded h-100">

        <h2>🚚</h2>
        <h5 class="fw-bold">Fast Delivery</h5>
        <p class="text-muted">
          We deliver products quickly across India within 2–3 days.
        </p>

      </div>
    </div>

    <!-- Service 2 -->
    <div class="col-md-4">
      <div class="p-4 shadow-sm bg-white rounded h-100">

        <h2>💳</h2>
        <h5 class="fw-bold">Secure Payment</h5>
        <p class="text-muted">
          100% safe payment system with multiple options like UPI, Card, Wallet.
        </p>

      </div>
    </div>

    <!-- Service 3 -->
    <div class="col-md-4">
      <div class="p-4 shadow-sm bg-white rounded h-100">

        <h2>⭐</h2>
        <h5 class="fw-bold">Best Quality</h5>
        <p class="text-muted">
          We provide only verified and high-quality products.
        </p>

      </div>
    </div>

    <!-- Service 4 (NEW ADDED) -->
    <div class="col-md-4">
      <div class="p-4 shadow-sm bg-white rounded h-100">

        <h2>🔄</h2>
        <h5 class="fw-bold">Easy Return</h5>
        <p class="text-muted">
          Hassle-free return and refund within few simple steps.
        </p>

      </div>
    </div>

    <!-- Service 5 (NEW ADDED) -->
    <div class="col-md-4">
      <div class="p-4 shadow-sm bg-white rounded h-100">

        <h2>📞</h2>
        <h5 class="fw-bold">24/7 Support</h5>
        <p class="text-muted">
          Our support team is always ready to help you anytime.
        </p>

      </div>
    </div>

    <!-- Service 6 (NEW ADDED) -->
    <div class="col-md-4">
      <div class="p-4 shadow-sm bg-white rounded h-100">

        <h2>🛍️</h2>
        <h5 class="fw-bold">Wide Products</h5>
        <p class="text-muted">
          Thousands of products across fashion, electronics & more.
        </p>

      </div>
    </div>

  </div>

</div>

<!-- EXTRA BANNER -->
<div class="bg-warning py-5">

  <div class="container text-center">

    <h3 class="fw-bold">🔥 Best Shopping Experience Guaranteed</h3>
    <p>We focus on customer satisfaction and fast service</p>

  </div>

</div>

{{>footer}}
</body>
</html>