<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Contact Us</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

{{>header}}
<body class="bg-light">

<!-- HERO -->
<div class="bg-dark text-light py-5">
  <div class="container text-center">

    <h1 class="fw-bold text-warning">Contact Us 📞</h1>
    <p class="lead">We are here to help you anytime</p>

  </div>
</div>

<!-- CONTACT SECTION -->
<div class="container my-5">

  <div class="row g-4">

    <!-- INFO BOX -->
    <div class="col-md-5">
      <div class="p-4 bg-white shadow rounded h-100">

        <h4 class="fw-bold text-dark mb-3">Get In Touch</h4>

        <p>📍 Ahmedabad, Gujarat</p>
        <p>📧 support@shopzone.com</p>
        <p>📞 +91 98765 43210</p>

        <hr>

        <h5 class="fw-bold text-warning">Working Hours</h5>
        <p>Mon - Fri: 9 AM - 6 PM</p>
        <p>Sat: 10 AM - 4 PM</p>
        <p>Sun: Closed</p>

      </div>
    </div>

    <!-- FORM -->
    <div class="col-md-7">
      <div class="p-4 bg-white shadow rounded">

        <h4 class="fw-bold text-dark mb-3">Send Message</h4>

        <form>

          <div class="mb-3">
            <label class="form-label">Name</label>
            <input type="text" class="form-control" placeholder="Enter your name">
          </div>

          <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" class="form-control" placeholder="Enter your email">
          </div>

          <div class="mb-3">
            <label class="form-label">Subject</label>
            <input type="text" class="form-control" placeholder="Subject">
          </div>

          <div class="mb-3">
            <label class="form-label">Message</label>
            <textarea class="form-control" rows="5" placeholder="Write your message"></textarea>
          </div>

          <button type="submit" class="btn btn-dark w-100">
            Send Message
          </button>

        </form>

      </div>
    </div>

  </div>

</div>

<!-- MAP -->
<div class="container mb-5">

  <div class="bg-white shadow rounded p-3">

    <h5 class="fw-bold text-center mb-3">Our Location</h5>

    <iframe
      src="https://www.google.com/maps?q=Ahmedabad&output=embed"
      width="100%" height="300"
      style="border:0;">
    </iframe>

  </div>

</div>

{{>footer}}
</body>
</html>