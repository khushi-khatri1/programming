<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>About Us</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

{{>header}}
<body class="bg-light">

<!-- HERO -->
<div class="bg-dark text-light py-5">
  <div class="container text-center">

    <h1 class="fw-bold text-warning">About ShopZone 🛒</h1>
    <p class="lead">Your trusted online shopping partner</p>

  </div>
</div>

<!-- ABOUT SECTION -->
<div class="container my-5">

  <div class="row align-items-center">

    <!-- IMAGE -->
    <div class="col-md-6 mb-4">
      <img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=800"
           class="img-fluid rounded shadow">
    </div>

    <!-- TEXT -->
    <div class="col-md-6">

      <h2 class="fw-bold text-dark">Who We Are</h2>

      <p class="text-muted">
        ShopZone is a modern e-commerce platform where users can buy fashion,
        electronics, and daily essentials at best prices with fast delivery.
      </p>

      <h4 class="mt-4 text-warning">🎯 Our Mission</h4>
      <p>
        To provide high-quality products with smooth shopping experience and customer satisfaction.
      </p>

      <h4 class="mt-4 text-warning">⭐ Why Choose Us?</h4>

      <ul class="list-group list-group-flush">
        <li class="list-group-item">✔ Trusted Products</li>
        <li class="list-group-item">✔ Fast Delivery</li>
        <li class="list-group-item">✔ Secure Payment</li>
        <li class="list-group-item">✔ Easy Return Policy</li>
      </ul>

    </div>

  </div>

</div>

<div class="container my-5">

  <!-- Heading -->
  <h2 class="text-center fw-bold mb-4">User Data Table</h2>

  <table class="table table-striped table-hover table-bordered text-center shadow-sm">

    <thead class="table-dark">
      <tr>
        <th>Firstname</th>
        <th>Email</th>
        <th>Country</th>
      </tr>
    </thead>

    <tbody>

      {{#each data}}

        <tr>
          <td>{{name}}</td>
          <td>{{email}}</td>
          <td>{{country}}</td>
        </tr>

      {{/each}}

    </tbody>

  </table>

</div>

<!-- STATS -->
<div class="bg-dark text-light py-5">

  <div class="container text-center">

    <div class="row">

      <div class="col-md-4">
        <h2 class="text-warning">10K+</h2>
        <p>Happy Customers</p>
      </div>

      <div class="col-md-4">
        <h2 class="text-warning">5K+</h2>
        <p>Products Sold</p>
      </div>

      <div class="col-md-4">
        <h2 class="text-warning">24/7</h2>
        <p>Support Available</p>
      </div>

    </div>

  </div>

</div>

<!-- EXTRA FEATURES -->
<div class="container my-5">

  <h3 class="text-center fw-bold mb-4">What Makes Us Special</h3>

  <div class="row g-4 text-center">

    <div class="col-md-4">
      <div class="p-4 shadow-sm bg-white rounded">
        <h5>🚚 Fast Delivery</h5>
        <p class="text-muted">Quick shipping across India.</p>
      </div>
    </div>

    <div class="col-md-4">
      <div class="p-4 shadow-sm bg-white rounded">
        <h5>💳 Secure Payment</h5>
        <p class="text-muted">Safe payment methods available.</p>
      </div>
    </div>

    <div class="col-md-4">
      <div class="p-4 shadow-sm bg-white rounded">
        <h5>⭐ Best Quality</h5>
        <p class="text-muted">Only verified products.</p>
      </div>
    </div>

  </div>

</div>

{{>footer}}
</body>
</html>