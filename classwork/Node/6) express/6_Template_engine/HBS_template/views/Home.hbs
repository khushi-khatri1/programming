<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>ShopZone Home</title>

  <!-- Bootstrap CDN -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

{{>header}}
<!-- HERO SECTION -->
<div class="bg-dark text-light py-5">
  <div class="container text-center">

    <h1 class="display-4 fw-bold">Welcome to ShopZone 🛒</h1>
    <p class="lead">Your one-stop destination for fashion, electronics, and daily essentials</p>

    <button class="btn btn-warning btn-lg me-2">Shop Now</button>
    <button class="btn btn-outline-light btn-lg">Explore Deals</button>

  </div>
</div>

<!-- FEATURES SECTION -->
<div class="container my-5">

  <div class="row text-center g-4">

    <div class="col-md-4">
      <div class="p-4 shadow-sm rounded bg-light">
        <h3>🚚 Fast Delivery</h3>
        <p class="text-muted">Get your orders delivered within 2–3 days anywhere in India.</p>
      </div>
    </div>

    <div class="col-md-4">
      <div class="p-4 shadow-sm rounded bg-light">
        <h3>🔒 Secure Payment</h3>
        <p class="text-muted">100% safe payment gateway with multiple options available.</p>
      </div>
    </div>

    <div class="col-md-4">
      <div class="p-4 shadow-sm rounded bg-light">
        <h3>⭐ Best Quality</h3>
        <p class="text-muted">We provide high-quality verified products at best prices.</p>
      </div>
    </div>

  </div>

</div>

<!-- CATEGORY SECTION -->
<div class="container my-5">

  <h2 class="text-center fw-bold mb-4">Shop by Category</h2>

  <div class="row g-4 text-center">

    <div class="col-md-3">
      <div class="p-4 border rounded shadow-sm">👕 Fashion</div>
    </div>

    <div class="col-md-3">
      <div class="p-4 border rounded shadow-sm">📱 Electronics</div>
    </div>

    <div class="col-md-3">
      <div class="p-4 border rounded shadow-sm">🏠 Home Decor</div>
    </div>

    <div class="col-md-3">
      <div class="p-4 border rounded shadow-sm">🍔 Food</div>
    </div>

  </div>

</div>

<!-- PRODUCT SECTION -->
<div class="container my-5">

  <h2 class="text-center fw-bold mb-4">Top Products</h2>

  <div class="row g-4">

    <!-- Product 1 -->
    <div class="col-md-3">
      <div class="card shadow-sm">
        <img src="https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?w=600" class="card-img-top" style="height:200px; object-fit:cover;">
        <div class="card-body text-center">
          <h5>Smartphone</h5>
          <p class="text-muted">₹15,999</p>
          <button class="btn btn-dark btn-sm">Buy Now</button>
        </div>
      </div>
    </div>

    <!-- Product 2 -->
    <div class="col-md-3">
      <div class="card shadow-sm">
        <img src="https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=600" class="card-img-top" style="height:200px; object-fit:cover;">        
        <div class="card-body text-center">
          <h5>Headphones</h5>
          <p class="text-muted">₹2,999</p>
          <button class="btn btn-dark btn-sm">Buy Now</button>
        </div>
      </div>
    </div>

    <!-- Product 3 -->
    <div class="col-md-3">
      <div class="card shadow-sm">
        <img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=600" class="card-img-top" style="height:200px; object-fit:cover;">
        <div class="card-body text-center">
          <h5>Watch</h5>
          <p class="text-muted">₹1,499</p>
          <button class="btn btn-dark btn-sm">Buy Now</button>
        </div>
      </div>
    </div>

    <!-- Product 4 -->
    <div class="col-md-3">
      <div class="card shadow-sm">
        <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=600" class="card-img-top" style="height:200px; object-fit:cover;">
        <div class="card-body text-center">
          <h5>Shoes</h5>
          <p class="text-muted">₹2,199</p>
          <button class="btn btn-dark btn-sm">Buy Now</button>
        </div>
      </div>
    </div>

  </div>

</div>

<!-- OFFER BANNER -->
<div class="bg-warning py-5 my-5">
  <div class="container text-center">

    <h2 class="fw-bold">🔥 Big Sale is Live!</h2>
    <p>Up to 70% OFF on selected products. Limited time offer!</p>

    <button class="btn btn-dark">Grab Deal</button>

  </div>
</div>

<!-- TESTIMONIALS -->
<div class="container my-5">

  <h2 class="text-center fw-bold mb-4">What Customers Say</h2>

  <div class="row g-4">

    <div class="col-md-4">
      <div class="p-4 border rounded shadow-sm">
        <p>"Amazing quality products and fast delivery!"</p>
        <h6>- Rahul</h6>
      </div>
    </div>

    <div class="col-md-4">
      <div class="p-4 border rounded shadow-sm">
        <p>"Best shopping experience ever. Highly recommended."</p>
        <h6>- Priya</h6>
      </div>
    </div>

    <div class="col-md-4">
      <div class="p-4 border rounded shadow-sm">
        <p>"Affordable prices and great customer support."</p>
        <h6>- Amit</h6>
      </div>
    </div>

  </div>

</div>

<!-- NEWSLETTER -->
<div class="bg-dark text-light py-5">
  <div class="container text-center">

    <h3 class="fw-bold">Subscribe to Our Newsletter</h3>
    <p>Get latest offers and updates directly to your email</p>

    <div class="row justify-content-center">
      <div class="col-md-6">

        <div class="input-group">
          <input type="email" class="form-control" placeholder="Enter your email">
          <button class="btn btn-warning">Subscribe</button>
        </div>

      </div>
    </div>

  </div>
</div>


{{>footer}}
</body>
</html>

